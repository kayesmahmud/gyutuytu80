# =========================================
# ThuluBazaar Production Environment
# Copy to .env on the EC2 server
# =========================================

# ---- Database ----
DB_USER=thulobazaar
DB_PASSWORD=CHANGE_ME_strong_password_here
DB_NAME=thulobazaar
DB_HOST=postgres
DB_PORT=5432
DATABASE_URL=postgresql://thulobazaar:CHANGE_ME@postgres:5432/thulobazaar

# ---- Security (generate with: openssl rand -base64 32) ----
JWT_SECRET=CHANGE_ME
JWT_EXPIRES_IN=24h
REFRESH_TOKEN_SECRET=CHANGE_ME
SESSION_SECRET=CHANGE_ME
NEXTAUTH_SECRET=CHANGE_ME

# ---- Google OAuth ----
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ---- URLs ----
NEXT_PUBLIC_API_URL=https://api.thulobazaar.com.np
NEXT_PUBLIC_SITE_URL=https://thulobazaar.com.np
NEXT_PUBLIC_API_HOSTNAME=api.thulobazaar.com.np
NEXTAUTH_URL=https://thulobazaar.com.np
FRONTEND_URL=https://thulobazaar.com.np
BACKEND_URL=https://api.thulobazaar.com.np
CORS_ORIGIN=https://thulobazaar.com.np

# ---- Typesense ----
TYPESENSE_API_KEY=CHANGE_ME_random_key

# ---- Email (SMTP) ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@thulobazaar.com.np

# ---- Docker Image Registry (set by CI/CD) ----
# ECR_REGISTRY=123456789.dkr.ecr.ap-south-1.amazonaws.com
# IMAGE_TAG=latest

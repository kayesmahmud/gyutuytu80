# =========================================
# Thulo Bazaar Production Environment
# Copy to .env on the EC2 server
# =========================================

# ---- Database ----
DB_USER=thulobazaar
DB_PASSWORD=CHANGE_ME_strong_password_here
DB_NAME=thulobazaar
DB_HOST=postgres
DB_PORT=5432
DATABASE_URL=postgresql://thulobazaar:CHANGE_ME@postgres:5432/thulobazaar

# ---- Security (generate with: openssl rand -base64 32) ----
JWT_SECRET=CHANGE_ME
JWT_EXPIRES_IN=24h
REFRESH_TOKEN_SECRET=CHANGE_ME
SESSION_SECRET=CHANGE_ME
NEXTAUTH_SECRET=CHANGE_ME

# ---- Google OAuth ----
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ---- URLs ----
NEXT_PUBLIC_API_URL=https://api.thulobazaar.com.np
NEXT_PUBLIC_SITE_URL=https://thulobazaar.com.np
NEXT_PUBLIC_APP_URL=https://thulobazaar.com.np
NEXT_PUBLIC_API_HOSTNAME=api.thulobazaar.com.np
NEXTAUTH_URL=https://thulobazaar.com.np
FRONTEND_URL=https://thulobazaar.com.np
BACKEND_URL=https://api.thulobazaar.com.np
APP_URL=https://api.thulobazaar.com.np
CORS_ORIGIN=https://thulobazaar.com.np

# ---- Typesense ----
TYPESENSE_API_KEY=CHANGE_ME_random_key

# ---- Email (SMTP) ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@thulobazaar.com.np

# ---- Payment Gateways ----
# Use 'production' with live keys when going live
KHALTI_ENV=sandbox
KHALTI_SECRET_KEY=live_secret_key_68791341fdd94846a146f0457ff7b455
KHALTI_PUBLIC_KEY=live_public_key_979320ffda8f45ebb2f35a31f9fc513c
ESEWA_ENV=sandbox
ESEWA_MERCHANT_CODE=EPAYTEST
ESEWA_SECRET_KEY=8gBm/:&EnhH.1/q

# ---- SMS (AakashSMS) ----
AAKASH_SMS_TOKEN=CHANGE_ME

